{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "auto react check --quiet",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 /workspaces/my-bot/scripts/gpt4o_hook.py",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "command": "python3 /workspaces/my-bot/scripts/gpt4o_hook.py",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "auto check --arch --quiet --warn-only",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/workspaces/my-bot/.claude/hooks/autopus/hook-claude-stop.sh",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Agent(*)",
      "AskUserQuestion(*)",
      "ToolSearch(*)",
      "TodoWrite(*)",
      "mcp__claude_ai_railway__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Drive__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Notion__*",
      "mcp__playwright__*",
      "mcp__railway__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "command": ".claude/statusline.sh",
    "padding": 1,
    "type": "command"
  }
}
